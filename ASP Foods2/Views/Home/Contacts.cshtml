@{
    ViewData["Title"] = "Контакти";
}

<div class="page-hero">
    <div class="container">
        <h1>Свържете се с <span class="text-gradient">Нас</span></h1>
        <p>Имате въпроси? Ще се радваме да ви помогнем. Свържете се с нашия екип.</p>
    </div>
</div>

<div class="container">
    <section class="sf-section" style="padding-top: 0;">
        <div class="contact-grid">
            <div class="contact-info">
                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <div>
                        <h5>Адрес</h5>
                        <p>ул. Здравословна 123<br>София 1000, България</p>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-telephone"></i>
                    </div>
                    <div>
                        <h5>Телефон</h5>
                        <p>+359 888 123 456<br>Пон-Пет: 9:00 - 18:00</p>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                    <div>
                        <h5>Имейл</h5>
                        <p>info@superfoods.bg<br>support@superfoods.bg</p>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-item-icon">
                        <i class="bi bi-clock"></i>
                    </div>
                    <div>
                        <h5>Работно Време</h5>
                        <p>Понеделник - Петък: 9:00 - 18:00<br>Събота: 10:00 - 14:00</p>
                    </div>
                </div>
            </div>

            <div class="contact-form">
                <h3 style="margin-bottom: 1.5rem; font-weight: 700;">Изпратете съобщение</h3>
                <form>
                    <div class="mb-3">
                        <label class="form-label">Вашето име</label>
                        <input type="text" class="form-control" placeholder="Иван Иванов">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Имейл адрес</label>
                        <input type="email" class="form-control" placeholder="ivan@example.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Тема</label>
                        <input type="text" class="form-control" placeholder="Въпрос относно продукт">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Съобщение</label>
                        <textarea class="form-control" rows="5" placeholder="Напишете вашето съобщение тук..."></textarea>
                    </div>
                    <button type="submit" class="btn-sf-submit">
                        <i class="bi bi-send"></i> Изпрати съобщение
                    </button>
                </form>
            </div>
        </div>
    </section>

    <section class="sf-section">
        <div class="sf-section-title">
            <h2>Често Задавани <span class="text-gradient">Въпроси</span></h2>
        </div>
        <div class="sf-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
            <div class="sf-card">
                <h3 style="font-size: 1.1rem;">Как мога да направя поръчка?</h3>
                <p>Изберете продуктите, добавете ги в количката и следвайте стъпките за плащане. Приемаме карти и наложен платеж.</p>
            </div>
            <div class="sf-card">
                <h3 style="font-size: 1.1rem;">Какви са сроковете за доставка?</h3>
                <p>Доставяме до 48 часа в работни дни до всяка точка в България. Безплатна доставка при поръчки над 100 лв.</p>
            </div>
            <div class="sf-card">
                <h3 style="font-size: 1.1rem;">Мога ли да върна продукт?</h3>
                <p>Да, имате право на връщане до 14 дни от получаването, ако продуктът е в оригинална опаковка.</p>
            </div>
        </div>
    </section>
</div>
